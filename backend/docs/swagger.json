    "definitions": {
        "dto.CreatePostRequest": {
            "type": "object",
            "properties": {
                "body": {
                    "type": "string"
                },
                "mediaPath": {
                    "type": "string"
                },
                "mediaType": {
                    "type": "string",
                    "enum": [
                        "image",
                        "video"
                    ]
                }
            }
        },
        "dto.CreateSessionRequest": {
            "type": "object",
            "properties": {
                "idToken": {
                    "type": "string"
                }
            }
        },
        "dto.CreateSessionResponse": {
            "type": "object",
            "properties": {
                "token": {
                    "type": "string"
                }
            }
        },
        "dto.ErrorDetail": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "dto.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "$ref": "#/definitions/dto.ErrorDetail"
                }
            }
        },
        "dto.PaginatedPostsResponse": {
            "type": "object",
            "properties": {
                "items": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/dto.Post"
                    }
                },
                "nextCursor": {
                    "type": "string"
                }
            }
        },
        "dto.Post": {
            "type": "object",
            "properties": {
                "authorId": {
                    "type": "string"
                },
                "body": {
                    "type": "string"
                },
                "createdAt": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "likeCount": {
                    "type": "integer"
                },
                "likedByMe": {
                    "type": "boolean"
                },
                "mediaPath": {
                    "type": "string"
                },
                "mediaType": {
                    "type": "string",
                    "enum": [
                        "image",
                        "video"
                    ]
                },
                "mediaUrl": {
                    "type": "string"
                }
            }
